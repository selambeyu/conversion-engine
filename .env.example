AT_USERNAME=
AT_API_KEY=

# HubSpot (fill in later)
HUBSPOT_ACCESS_TOKEN=

# Resend email (fill in later)
RESEND_API_KEY=
# Langfuse — get these from cloud.langfuse.com > Settings > API Keys
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# OpenRouter — for dev-tier models (Qwen3 / DeepSeek V3.2)
# Get key at openrouter.ai
OPENROUTER_API_KEY=sk-or-...

# Dev-tier model pinned by program staff on Day 0
# Default: Qwen3-Next-80B-A3B  |  Alternative: deepseek/deepseek-chat-v3-2
TAU2_MODEL=qwen/qwen3-235b-a22b
TAU2_TEMPERATURE=0.0

# tau2-bench repo path — already cloned at ../tau2-bench relative to this project
TAU2_BENCH_PATH=../tau2-bench

# Eval settings
EVAL_DOMAIN=retail
EVAL_TRIALS=5
DEV_SLICE_SIZE=30
HELD_OUT_SLICE_SIZE=20

# Kill switch — set to "true" only for live production sends
# When false (default), all email/SMS is redirected to STAFF_SINK_EMAIL / STAFF_SINK_PHONE
PRODUCTION_MODE=false
STAFF_SINK_EMAIL=dev-sink@tenacious.com
STAFF_SINK_PHONE=+254700000000

# NewsAPI (free tier — 100 req/day, register at newsapi.org)
# Used for live executive commentary signal in AI maturity scoring
# Leave blank to use only static Crunchbase fields
NEWS_API_KEY=
